# =============================================================================
# ELECTRICITY MVP - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# =============================================================================

# -----------------------------------------------------------------------------
# AUTH (required)
# -----------------------------------------------------------------------------
# Password for manager login (simple password-based auth for MVP)
MANAGER_PASSWORD=your-secure-manager-password

# Password for employee login
EMPLOYEE_PASSWORD=your-secure-employee-password

# Session secret - used to sign session cookies (use a random 32+ char string)
SESSION_SECRET=your-random-32-character-session-secret-here

# -----------------------------------------------------------------------------
# GOOGLE CLOUD (required for Google Sheets & Drive)
# -----------------------------------------------------------------------------
# In Google Cloud Console → APIs & Services → Library: enable BOTH for this project:
#   - Google Sheets API (data)
#   - Google Drive API (receipt uploads) — required even if Sheets already works
# Google Service Account - JSON credentials (paste full JSON as single line, or use file path)
# Option 1: Path to JSON file (relative to project root)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Option 2: Inline JSON (for Vercel - paste the entire JSON object as one line)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Google Sheets document ID (from the URL: docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/edit)
GOOGLE_SHEETS_ID=your-google-sheet-id

# Google Drive folder ID where receipt images will be stored (from URL: drive.google.com/drive/folders/FOLDER_ID)
# If uploads break without you changing env: folder may have moved to a Shared Drive (needs service account access),
# or Google Workspace may block “anyone with the link” sharing on the second step of upload.
GOOGLE_DRIVE_RECEIPTS_FOLDER_ID=your-drive-folder-id

# -----------------------------------------------------------------------------
# OPTIONAL
# -----------------------------------------------------------------------------
# Base URL for the app (used in links) - defaults to localhost in dev
# NEXT_PUBLIC_APP_URL=http://localhost:3000
